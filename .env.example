# Frontline — environment variables

# Anthropic API (required for generate + critique stages)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot (required for publishing to channel)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@frontline_ua  # or numeric -100...

# Pipeline tuning
FRONTLINE_DAILY_PAPER_LIMIT=10        # max papers to process per day
FRONTLINE_DAILY_COST_CAP_USD=1.0      # hard stop if exceeded
FRONTLINE_MODEL_GENERATE=claude-sonnet-4-6
FRONTLINE_MODEL_CRITIQUE=claude-opus-4-7

# Local dev
FRONTLINE_DRY_RUN=false               # if true: no Telegram publish, no commits
FRONTLINE_OUTPUT_DIR=.runs            # where local runs land
