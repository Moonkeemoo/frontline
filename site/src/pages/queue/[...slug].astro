---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import FileViewer from "../../components/FileViewer.astro";
import { sourceLabel } from "../../utils";

export async function getStaticPaths() {
  const items = await getCollection("queue");
  return items.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const critique = item.data.critique;
const issues = critique?.issues ?? [];
---

<Layout title={`[черга] ${item.data.title} — Frontline`} description={item.data.tldr}>
  <FileViewer
    label={`queue/${item.id}.md`}
    icon="file"
    status={`-- QUEUE-ITEM -- verdict=${critique?.verdict ?? "?"} · ${issues.length} issues · awaiting review`}
  >
    <div class="alert alert-attention">
      <strong>⚠ Цей пост у черзі на ревʼю</strong>
      Не пройшов auto-publish gate. Критик-LLM повернув verdict
      <code>{critique?.verdict ?? "—"}</code>, recommendation
      <code>{critique?.recommendation ?? "—"}</code>.
    </div>

    <h1>{item.data.title}</h1>

    <blockquote>
      <strong>TL;DR.</strong> {item.data.tldr}
    </blockquote>

    <p class="meta">
      <span class="arxiv">{sourceLabel(item.data.source)}:{item.data.arxiv_id}</span>
      <span class="dot">·</span>
      <span>{item.data.publish_date}</span>
    </p>

    <p class="tag-list">
      {item.data.tags.map((tag) => <span class="tag">{tag}</span>)}
    </p>

    {issues.length > 0 && (
      <>
        <h2>Зауваження критика ({issues.length})</h2>
        <ol class="issues">
          {issues.map((issue) => (
            <li>
              <p>
                <span class={`severity-pill severity-${issue.severity}`}>
                  {issue.severity}
                </span>
                <code>{issue.category}</code>
              </p>
              <p><strong>{issue.description}</strong></p>
              <blockquote>{issue.evidence}</blockquote>
            </li>
          ))}
        </ol>
        {critique?.regenerate_feedback && (
          <>
            <h3>Рекомендація для regenerate</h3>
            <blockquote>{critique.regenerate_feedback}</blockquote>
          </>
        )}
      </>
    )}

    <h2>Текст резюме</h2>

    <Content />

    <hr />

    <p>
      <strong>Автори:</strong>{" "}
      <span class="muted">{item.data.authors.join(", ")}</span>
    </p>
    <p>
      <a href={item.data.arxiv_url} target="_blank" rel="noopener"
        >Читати оригінал на arXiv ↗</a
      >
    </p>
  </FileViewer>
</Layout>

<style>
  .breadcrumb { display: none; }
  ._breadcrumb {
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Consolas, monospace;
    font-size: 14px;
    color: var(--color-fg-muted);
    margin: 0 0 12px;
  }
  .breadcrumb a { color: var(--color-link); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .breadcrumb .sep { margin: 0 6px; opacity: 0.5; }
  .breadcrumb .current { color: var(--color-fg); }

  .muted { color: var(--color-fg-muted); }
  .issues { padding-left: 1.5em; }
  .issues > li + li { margin-top: 16px !important; }
</style>
