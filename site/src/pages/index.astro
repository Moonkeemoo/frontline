---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import FileViewer from "../components/FileViewer.astro";

const posts = (await getCollection("posts")).sort(
  (a, b) =>
    new Date(b.data.publish_date).getTime() -
    new Date(a.data.publish_date).getTime(),
);
---

<Layout>
  <FileViewer label="README.md" icon="book">
    <h1>Frontline</h1>

    <blockquote>
      <strong>Свіжі AI/ML дослідження українською</strong> — TL;DR, прикладний
      контекст для українського IT-сектора, лінк на першоджерело.
    </blockquote>

    <p>
      Автоматичний агрегатор, що збирає свіжі дослідження з <a
        href="https://huggingface.co/papers"
        target="_blank"
        rel="noopener">HuggingFace Papers</a> і <a
        href="https://arxiv.org"
        target="_blank"
        rel="noopener">arXiv</a> (категорії <code>cs.LG</code>, <code>cs.AI</code>,
      <code>cs.CL</code>, <code>cs.CV</code>, <code>cs.SE</code>,
      <code>cs.DB</code>, <code>cs.CR</code>, <code>cs.DC</code>), генерує
      українською мовою резюме і публікує сюди + у Telegram.
    </p>

    <h2>Останні пости</h2>

    {posts.length === 0 ? (
      <p><em>Поки що пусто — pipeline ще не запустився сьогодні.</em></p>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <h3 class="post-title">
              <a href={`/posts/${post.id}/`}>{post.data.title}</a>
            </h3>
            <p class="meta">
              <span class="arxiv">arXiv:{post.data.arxiv_id}</span>
              <span class="dot">·</span>
              <span>{post.data.read_min} хв</span>
              <span class="dot">·</span>
              <span>{post.data.publish_date}</span>
            </p>
            <p class="post-tldr">{post.data.tldr}</p>
            <p class="tag-list">
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </p>
          </li>
        ))}
      </ul>
    )}

    <h2>Про проєкт</h2>
    <p>
      Як працює pipeline і чому ми робимо саме так — <a href="/about/"
        >ABOUT.md</a
      >. Що зараз у черзі на ревʼю — <a href="/queue/">queue/</a>.
    </p>
  </FileViewer>
</Layout>

<style>
  .post-list {
    list-style: none;
    padding-left: 0 !important;
  }
  .post-list > li {
    border-top: 1px solid var(--color-border-muted);
    padding: 20px 0;
  }
  .post-list > li:last-child {
    border-bottom: 1px solid var(--color-border-muted);
  }
  .post-list > li + li { margin-top: 0; }
  .post-title {
    font-size: 1.2em !important;
    margin: 0 0 6px !important;
    border: none !important;
    padding: 0 !important;
  }
  .post-title a { color: var(--color-fg); text-decoration: none; }
  .post-title a:hover { color: var(--color-link); text-decoration: underline; }
  .post-tldr {
    margin: 8px 0 10px !important;
    color: var(--color-fg);
  }
</style>
